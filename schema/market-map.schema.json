{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schema/market-map.schema.json",
  "title": "Market Atlas Graph Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "nodes",
    "edges",
    "views",
    "layout_presets",
    "source_refs"
  ],
  "properties": {
    "meta": { "$ref": "#/$defs/meta" },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" },
      "uniqueItems": true
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" },
      "uniqueItems": true
    },
    "views": {
      "type": "array",
      "items": { "$ref": "#/$defs/view" },
      "uniqueItems": true
    },
    "layout_presets": {
      "type": "array",
      "items": { "$ref": "#/$defs/layoutPreset" },
      "uniqueItems": true
    },
    "source_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceRef" },
      "uniqueItems": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{1,127}$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "stringArray": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "nodeType": {
      "type": "string",
      "enum": [
        "organization",
        "public_entity",
        "hybrid_entity",
        "ecosystem_actor",
        "cluster",
        "institution",
        "investor",
        "business_unit"
      ]
    },
    "buyerType": {
      "type": "string",
      "enum": [
        "private",
        "public",
        "hybrid",
        "growth",
        "channel",
        "unknown"
      ]
    },
    "edgeType": {
      "type": "string",
      "enum": [
        "ownership",
        "subsidiary_of",
        "partner_of",
        "member_of",
        "collaborates_with",
        "channel_to",
        "procures_via",
        "adjacent_to",
        "operates_in"
      ]
    },
    "relevanceLevel": {
      "type": "string",
      "enum": ["none", "low", "medium", "high"]
    },
    "sizeBand": {
      "type": "string",
      "enum": ["micro", "small", "medium", "large", "enterprise", "unknown"]
    },
    "ownershipType": {
      "type": "string",
      "enum": ["private", "public", "mixed", "foundation", "cooperative", "unknown"]
    },
    "procurementRegime": {
      "type": "string",
      "enum": [
        "private",
        "public_procurement",
        "utilities",
        "hybrid",
        "framework",
        "dps",
        "health_centralized",
        "unknown"
      ]
    },
    "opportunityBand": {
      "type": "string",
      "enum": ["tier_1", "tier_2", "tier_3", "tier_4", "watchlist", "unknown"]
    },
    "relationshipStatus": {
      "type": "string",
      "enum": ["none", "known", "warm", "active", "existing_client", "unknown"]
    },
    "confidenceLevel": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "corridorZone": {
      "type": "string",
      "enum": [
        "south",
        "south_jaeren",
        "east_jaeren",
        "core",
        "north_edge",
        "outside_corridor",
        "unknown"
      ]
    },
    "buyingMode": {
      "type": "string",
      "enum": [
        "specialist",
        "paired_specialists",
        "pod",
        "team",
        "managed_delivery",
        "retained_partner",
        "framework_route",
        "unknown"
      ]
    },
    "needCategory": {
      "type": "string",
      "enum": [
        "design_execution",
        "service_design",
        "strategic_design",
        "innovation_support",
        "ai_enablement",
        "software_modernization",
        "software_development",
        "product_development",
        "team_augmentation",
        "development_partner"
      ]
    },
    "sourceType": {
      "type": "string",
      "enum": ["official", "primary", "secondary", "internal_note"]
    },
    "layoutType": {
      "type": "string",
      "enum": ["force", "preset", "geo"]
    },
    "operator": {
      "type": "string",
      "enum": ["eq", "neq", "in", "not_in", "gte", "lte", "contains", "exists"]
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "title", "version", "updated_at"],
      "properties": {
        "project_id": { "$ref": "#/$defs/id" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "updated_at": { "$ref": "#/$defs/date" },
        "default_view_id": { "$ref": "#/$defs/id" },
        "locale": { "type": "string", "default": "en" },
        "corridor_description": { "type": "string" }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["municipality", "zone"],
      "properties": {
        "municipality": { "type": "string", "minLength": 1 },
        "subarea": { "type": "string" },
        "zone": { "$ref": "#/$defs/corridorZone" },
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "attributes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "size_band",
        "ownership_type",
        "procurement_regime",
        "design_relevance",
        "ai_relevance",
        "software_relevance",
        "product_relevance",
        "likely_needs",
        "likely_buying_modes",
        "opportunity_band",
        "relationship_status"
      ],
      "properties": {
        "size_band": { "$ref": "#/$defs/sizeBand" },
        "ownership_type": { "$ref": "#/$defs/ownershipType" },
        "procurement_regime": { "$ref": "#/$defs/procurementRegime" },
        "design_relevance": { "$ref": "#/$defs/relevanceLevel" },
        "ai_relevance": { "$ref": "#/$defs/relevanceLevel" },
        "software_relevance": { "$ref": "#/$defs/relevanceLevel" },
        "product_relevance": { "$ref": "#/$defs/relevanceLevel" },
        "likely_needs": {
          "type": "array",
          "items": { "$ref": "#/$defs/needCategory" },
          "uniqueItems": true
        },
        "likely_buying_modes": {
          "type": "array",
          "items": { "$ref": "#/$defs/buyingMode" },
          "uniqueItems": true
        },
        "opportunity_band": { "$ref": "#/$defs/opportunityBand" },
        "relationship_status": { "$ref": "#/$defs/relationshipStatus" }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "why_it_matters"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "why_it_matters": { "type": "string", "minLength": 1 },
        "relevant_to_olavstoppen": { "type": "string" },
        "likely_sponsor_roles": { "$ref": "#/$defs/stringArray" },
        "notes": { "$ref": "#/$defs/stringArray" }
      }
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confidence_level"],
      "properties": {
        "commercial_attractiveness": { "type": "number", "minimum": 0, "maximum": 100 },
        "short_term_opportunity": { "type": "number", "minimum": 0, "maximum": 100 },
        "access_difficulty": { "type": "number", "minimum": 0, "maximum": 100 },
        "confidence_level": { "$ref": "#/$defs/confidenceLevel" },
        "score_date": { "$ref": "#/$defs/date" }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "type",
        "buyer_type",
        "sector",
        "location",
        "attributes",
        "profile",
        "scores",
        "tags",
        "source_refs"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "type": "string", "minLength": 1 },
        "aliases": { "$ref": "#/$defs/stringArray" },
        "type": { "$ref": "#/$defs/nodeType" },
        "buyer_type": { "$ref": "#/$defs/buyerType" },
        "sector": { "type": "string", "minLength": 1 },
        "subsector": { "type": "string" },
        "location": { "$ref": "#/$defs/location" },
        "attributes": { "$ref": "#/$defs/attributes" },
        "profile": { "$ref": "#/$defs/profile" },
        "scores": { "$ref": "#/$defs/scores" },
        "tags": { "$ref": "#/$defs/stringArray" },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        }
      }
    },
    "edgeAttributes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "notes": { "$ref": "#/$defs/stringArray" },
        "confidence_level": { "$ref": "#/$defs/confidenceLevel" }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source",
        "target",
        "type",
        "directed",
        "strength",
        "tags",
        "source_refs"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "source": { "$ref": "#/$defs/id" },
        "target": { "$ref": "#/$defs/id" },
        "type": { "$ref": "#/$defs/edgeType" },
        "label": { "type": "string" },
        "directed": { "type": "boolean" },
        "strength": { "type": "number", "minimum": 0, "maximum": 1 },
        "attributes": { "$ref": "#/$defs/edgeAttributes" },
        "tags": { "$ref": "#/$defs/stringArray" },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        }
      }
    },
    "filterRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "operator"],
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "operator": { "$ref": "#/$defs/operator" },
        "value": {
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            {
              "type": "array",
              "items": {
                "oneOf": [
                  { "type": "string" },
                  { "type": "number" },
                  { "type": "boolean" }
                ]
              },
              "uniqueItems": true
            }
          ]
        }
      }
    },
    "viewStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "node_color_by": { "type": "string" },
        "node_size_by": { "type": "string" },
        "node_shape_by": { "type": "string" },
        "label_mode": {
          "type": "string",
          "enum": ["focused", "all", "none", "top_ranked"]
        },
        "edge_visibility": {
          "type": "string",
          "enum": ["all", "strong_only", "focused_only"]
        },
        "show_legend": { "type": "boolean" },
        "show_geo_overlay": { "type": "boolean" }
      }
    },
    "viewDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "focus_hops": { "type": "integer", "minimum": 1, "maximum": 3 },
        "show_profile_on_click": { "type": "boolean" },
        "hide_weak_edges_below": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "node_filters", "edge_filters", "style"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "node_filters": {
          "type": "array",
          "items": { "$ref": "#/$defs/filterRule" }
        },
        "edge_filters": {
          "type": "array",
          "items": { "$ref": "#/$defs/filterRule" }
        },
        "style": { "$ref": "#/$defs/viewStyle" },
        "defaults": { "$ref": "#/$defs/viewDefaults" },
        "layout_preset_id": { "$ref": "#/$defs/id" }
      }
    },
    "layoutPosition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "x", "y"],
      "properties": {
        "node_id": { "$ref": "#/$defs/id" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "pinned": { "type": "boolean" }
      }
    },
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "zoom": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "layoutPreset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "type"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "type": "string", "minLength": 1 },
        "type": { "$ref": "#/$defs/layoutType" },
        "positions": {
          "type": "array",
          "items": { "$ref": "#/$defs/layoutPosition" }
        },
        "viewport": { "$ref": "#/$defs/viewport" }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "type"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "type": "string", "minLength": 1 },
        "type": { "$ref": "#/$defs/sourceType" },
        "publisher": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "published_at": { "$ref": "#/$defs/date" },
        "accessed_at": { "$ref": "#/$defs/date" },
        "notes": { "$ref": "#/$defs/stringArray" }
      }
    }
  }
}
